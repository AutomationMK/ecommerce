{{template "base" .}}

{{define "title"}}
Payment Receipt
{{end}}

{{define "content"}}
<h2 class="mt-5">Payment Succeeded</h2>
<hr>
<p>Payment Intent: {{index .Data "pi"}}</p>
<p>Cardholder: {{index .Data "cardholder"}}</p>
<p>Cardholder Email: {{index .Data "cardholder_email"}}</p>
<p>Payment Method: {{index .Data "pm"}}</p>
<p>Payment Amount: {{index .Data "pa"}}</p>
<p>Payment Currency: {{index .Data "pc"}}</p>
{{end}}
